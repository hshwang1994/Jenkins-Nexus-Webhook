#!/usr/bin/env bash
# ============================================================
# install.env — 오프라인 설치 환경 설정 (SSOT)
#
# ★ 핵심: NEXUS_ROLE 로 서버 역할을 결정한다.
#   primary   = 178 이천 (hosted 2개 + webhook)
#   secondary = 179 용인 / 180 청주 (proxy cache 1개)
#
# ★ Repository 2계열:
#   application-install-raw  — 일반 배포 파일 (Primary hosted + Secondary proxy)
#   infra-automation-raw     — 포털 업로드/삭제 대상 (Primary hosted only, webhook)
# ============================================================

# --- 서버 역할 ---
NEXUS_ROLE="primary"

# --- Primary Nexus 주소 (secondary 전용) ---
PRIMARY_NEXUS_URL="http://10.100.64.178:8081"

# --- Nexus ---
NEXUS_VERSION="3.91.0-07"
NEXUS_ARCHIVE="nexus-${NEXUS_VERSION}-linux-x86_64.tar.gz"
NEXUS_DOWNLOAD_URL="https://download.sonatype.com/nexus/3/${NEXUS_ARCHIVE}"
NEXUS_INSTALL_BASE="/opt/sonatype"
NEXUS_INSTALL_DIR="${NEXUS_INSTALL_BASE}/nexus"
NEXUS_REAL_DIR="${NEXUS_INSTALL_BASE}/nexus-${NEXUS_VERSION}"
NEXUS_DATA_DIR="/nexus-data"
NEXUS_USER="nexus"
NEXUS_GROUP="nexus"
NEXUS_HTTP_PORT="8081"
NEXUS_HOST="0.0.0.0"

# --- JVM ---
# 178 (8 GB):  heap 2g, direct 2g  → 수동 조정 필요
# 179/180 (16 GB): heap 4g, direct 4g
NEXUS_JVM_HEAP_MIN="4g"
NEXUS_JVM_HEAP_MAX="4g"
NEXUS_JVM_DIRECT_MEMORY="4g"

# --- PostgreSQL 16 ---
PG_VERSION="16"
PG_SERVICE="postgresql-${PG_VERSION}"
PG_DATA_DIR="/var/lib/pgsql/${PG_VERSION}/data"
PG_PORT="5432"
PG_DB_NAME="nexusdb"
PG_DB_USER="nexus"
PG_DB_PASSWORD="Goodmit0802!"
PG_MAX_CONNECTIONS="200"
PG_SHARED_BUFFERS="1024MB"
PG_WORK_MEM="32MB"
PG_EFFECTIVE_CACHE_SIZE="3072MB"

# --- Nginx ---
NGINX_LISTEN_PORT="80"
NGINX_SSL_ENABLED="false"
NGINX_SERVER_NAME="_"

# --- 번들 경로 ---
BUNDLE_DIR="/opt/nexus-bundle"

# --- 운영 설정 ---
CONFIG_DIR="/etc/nexus-offline"
LOG_DIR="${BUNDLE_DIR}/logs"

# --- Nexus 초기 설정 ---
NEXUS_ADMIN_PASSWORD="Goodmit0802!"
NEXUS_ANONYMOUS_ACCESS="false"

# ============================================================
# Repository 계열 1: application-install-raw
# 용도: 일반 배포 파일 (애플리케이션 설치 패키지 등)
# 구조: 178 hosted + 179/180 proxy cache
# ============================================================
APP_HOSTED_REPO_NAME="application-install-raw-hosted"
APP_PROXY_REPO_NAME="application-install-raw-proxy"

# ============================================================
# Repository 계열 2: infra-automation-raw (Primary 178 전용)
# 용도: 포털 업로드/삭제 대상, OOB 파일 동기화 원본
# 구조: 178 hosted only — 179/180은 proxy 하지 않음
# Webhook 발송 대상: 이 repository의 component 이벤트
# ============================================================
INFRA_HOSTED_REPO_NAME="infra-automation-raw-hosted"

# --- 공통 ---
RAW_REPO_WRITE_POLICY="allow"
BLOB_STORE_NAME="default"

# --- 서비스 계정 ---
SVC_ACCOUNT_USER="svc_app_install_read"
SVC_ACCOUNT_PASSWORD="Goodmit0802!"

# --- Webhook (Primary 전용, infra-automation-raw-hosted 대상) ---
# Webhook 발송 주체는 178 Primary만. infra-automation-raw-hosted의 component 이벤트.
# 179/180 Secondary에서는 무시됨.
WEBHOOK_HMAC_SECRET="Goodmit0802!"
WEBHOOK_EVENT_TYPES="component"
WEBHOOK_URL_PROD="http://10.100.64.198:8080/generic-webhook-trigger/invoke?token=infra-automation-nexus-webhook"
WEBHOOK_URL_DEV="http://10.100.64.199:8080/generic-webhook-trigger/invoke?token=infra-automation-nexus-webhook"

# --- SSH (원격 배포용) ---
SSH_USER="cloviradmin"
SSH_PASSWORD="Goodmit0802!"

# --- 서버 토폴로지 (참조용) ---
# 178 이천 = Primary
#   - application-install-raw-hosted (hosted)
#   - infra-automation-raw-hosted (hosted, webhook → Jenkins)
# 179 용인 = Secondary
#   - application-install-raw-proxy (proxy → 178)
# 180 청주 = Secondary
#   - application-install-raw-proxy (proxy → 178)
