// ============================================================
// master_reconcile
//
// 주기 점검 (부분 / 전체).
// Nexus ↔ 로컬 비교로 누락/과잉/삭제 누락을 복구한다.
//
// 새 네트워크 전제 반영:
//   - Nexus asset 목록 조회: Master에서 실행
//   - 파일 다운로드: Master에서 실행 → seed에 전송
//   - seed → peer fan-out
//   - OOB Agent가 Nexus에 직접 접근하지 않음
//
// partial: 최근 변경분 + 최근 실패분 + 신규 OOB catch-up
// full:    전체 asset 비교 + quarantine 최종 삭제
// ============================================================

import jenkins.model.Jenkins

def mode = params.mode ?: 'partial'
def retention = (mode == 'full') ? [num: '14', days: '30'] : [num: '30', days: '14']

properties([
  buildDiscarder(logRotator(numToKeepStr: retention.num, daysToKeepStr: retention.days)),
  parameters([
    choice(name: 'mode', choices: ['partial','full'])
  ]),
  pipelineTriggers([
    cron(mode == 'full' ? 'H 3 * * *' : 'H/30 * * * *')
  ])
])

def sync_cfg = null

pipeline {
  agent { label 'built-in' }
  environment {
    SYNC_CONFIG_PATH       = '/etc/oob-sync/sync_config.yml'
    ANSIBLE_PLAYBOOK_DIR   = '/opt/oob-sync/ansible/playbooks'
  }
  stages {
    stage('1. 공통 설정 로드') {
      steps {
        script {
          sync_cfg = readYaml(file: env.SYNC_CONFIG_PATH)
          if (!sync_cfg.nexus?.allowed_repositories) {
            error("""[동기화 대상 repository 미설정]

발생상황:
sync_config.yml 의 nexus.allowed_repositories 가 비어 있습니다.

조치방법:
1. /etc/oob-sync/sync_config.yml 의 nexus.allowed_repositories 에 대상 repository 이름을 등록합니다.
2. 예: allowed_repositories: ['infra-automation-raw-hosted']""")
          }
          echo "[주기 점검 시작] mode=${params.mode} repos=${sync_cfg.nexus.allowed_repositories}"
        }
      }
    }

    stage('2. Master에서 Nexus asset 목록 조회') {
      steps {
        script {
          // Master에서 Nexus REST API 호출 (Master ↔ Nexus 통신 가능)
          withCredentials([
            usernamePassword(credentialsId: sync_cfg.nexus.credentials_id,
                             usernameVariable: 'NEXUS_USER', passwordVariable: 'NEXUS_PASS')
          ]) {
            env.NEXUS_ASSETS_JSON = sh(returnStdout: true, script: """
              python3 "${env.ANSIBLE_PLAYBOOK_DIR}/../scripts/list_nexus_assets.py" \
                --nexus-url "${sync_cfg.nexus.base_url}" \
                --repository "${sync_cfg.nexus.allowed_repositories[0]}" \
                --username "\$NEXUS_USER" \
                --password "\$NEXUS_PASS" \
                --mode "${params.mode}"
            """).trim()
          }
          echo "[Nexus asset 목록 조회 완료] Master에서 실행"
        }
      }
    }

    stage('3. 리전별 점검 실행') {
      steps {
        script {
          def region_results = [:]
          for (loc in sync_cfg.location_codes) {
            region_results[loc] = reconcileOneRegion(loc, sync_cfg, params.mode)
          }
          def failed = region_results.findAll { k, v -> !v.success }
          if (failed) {
            echo """[일부 리전 주기 점검 실패]

발생상황:
${failed.keySet()} 리전에서 주기 점검(${params.mode})이 실패했습니다.

조치방법:
다음 주기 점검에서 자동 재시도합니다."""
            currentBuild.result = 'UNSTABLE'
          }
        }
      }
    }
  }
}

def reconcileOneRegion(String location_code, def sync_cfg, String mode) {
  def selector = "${location_code} && ${sync_cfg.oob_selector_label}"
  def candidate = nodesByLabel(label: selector, offline: true)
  def online = []
  def offline = []
  def excluded = []

  candidate.each { name ->
    if (sync_cfg.exclude_node_names?.contains(name)) { excluded << name; return }
    def c = Jenkins.get().getNode(name)?.toComputer()
    if (c?.isOnline()) online << name else offline << name
  }

  if (online.isEmpty()) {
    echo "[${location_code}] 온라인 OOB Agent 없음 — 점검 중단"
    return [success: false]
  }

  def selected_seed_node  = pickSeedForReconcile(online)
  def selected_peer_nodes = online.findAll { it != selected_seed_node }

  // agent_ip_map 기반 IP 해소
  def ip_map = sync_cfg.agent_ip_map ?: [:]
  def seed_ip = ip_map[selected_seed_node] ?: selected_seed_node
  def ssh_user = sync_cfg.master_to_seed?.ssh_user ?: 'cloviradmin'
  def ssh_opts = sync_cfg.master_to_seed?.ssh_options ?: '-o StrictHostKeyChecking=no -o ConnectTimeout=10'
  echo "[${location_code}] seed=${selected_seed_node}(${seed_ip}) peers=${selected_peer_nodes}"

  // seed에서 로컬 파일 목록 수집
  def local_files_json = ''
  node(selected_seed_node) {
    local_files_json = sh(returnStdout: true, script: """
      find '${sync_cfg.sync_root_path}' -type f 2>/dev/null | \
        sed 's|^${sync_cfg.sync_root_path}/||' | \
        python3 -c "import sys,json; print(json.dumps([l.strip() for l in sys.stdin if l.strip()]))"
    """).trim()
  }

  // Master에서 비교: 누락/과잉 계산
  // Nexus path: /fanout-final/test.txt → infra-automation-raw-hosted/fanout-final/test.txt
  def repo_name = sync_cfg.nexus.allowed_repositories[0]
  def nexus_paths = new groovy.json.JsonSlurper().parseText(env.NEXUS_ASSETS_JSON ?: '[]').collect {
    def p = it.path?.replaceFirst('^/', '') ?: ''
    "${repo_name}/${p}"
  }
  def local_paths = new groovy.json.JsonSlurper().parseText(local_files_json ?: '[]')
  def missing = nexus_paths.findAll { !(it in local_paths) }
  def orphans = local_paths.findAll { !(it in nexus_paths) }

  echo "[${location_code}] 누락=${missing.size()} 과잉=${orphans.size()}"

  // 누락 파일: Master에서 다운로드 → seed 전송
  def ok = true
  if (missing) {
    withCredentials([
      usernamePassword(credentialsId: sync_cfg.nexus.credentials_id,
                       usernameVariable: 'NEXUS_USER', passwordVariable: 'NEXUS_PASS'),
      sshUserPrivateKey(credentialsId: 'jenkins-ssh-key',
                        keyFileVariable: 'OOB_SSH_KEY', usernameVariable: 'OOB_SSH_USER')
    ]) {
      missing.each { rel_path ->
        def download_url = "${sync_cfg.nexus.base_url}/repository/${rel_path}"
        def staging_file = "${sync_cfg.master_staging_path}/${rel_path}"
        def seed_final = "${sync_cfg.sync_root_path}/${rel_path}"

        def rc = sh(returnStatus: true, script: """
          mkdir -p "\$(dirname '${staging_file}')"
          curl -fSL --max-time ${sync_cfg.nexus.api_timeout_seconds} \
            -u "\$NEXUS_USER:\$NEXUS_PASS" \
            -o '${staging_file}' '${download_url}' && \
          ssh ${ssh_opts} -i "\$OOB_SSH_KEY" \
            ${ssh_user}@${seed_ip} \
            "mkdir -p '\$(dirname '${seed_final}')'" && \
          scp ${ssh_opts} -i "\$OOB_SSH_KEY" \
            '${staging_file}' \
            ${ssh_user}@${seed_ip}:'${seed_final}' && \
          rm -f '${staging_file}'
        """)
        if (rc != 0) {
          echo "[${location_code}] 누락 파일 복구 실패: ${rel_path}"
          ok = false
        }
      }
    }
  }

  // seed → same-region peer rsync 전파 (jenkins key, catch-up 포함)
  if (selected_peer_nodes) {
    def jenkins_key = "/home/jenkins/.ssh/id_rsa"
    node(selected_seed_node) {
        selected_peer_nodes.each { peer ->
          def peer_ip = ip_map[peer] ?: peer
          def rsync_rc = sh(returnStatus: true, script: """
            rsync -avz --partial --delete --timeout=300 \
              -e "ssh -i ${jenkins_key} -o StrictHostKeyChecking=no -o ConnectTimeout=10" \
              '${sync_cfg.sync_root_path}/' \
              '${ssh_user}@${peer_ip}:${sync_cfg.sync_root_path}/'
          """)
          if (rsync_rc != 0) {
            echo "[${location_code}] peer(${peer}) 전파 실패"
          }
        }
      }
    }

  // quarantine 최종 삭제 (full 모드) — seed + peer 모두에서
  if (mode == 'full') {
    def all_nodes_del = [selected_seed_node] + selected_peer_nodes
    def jenkins_key_del = "/home/jenkins/.ssh/id_rsa"

    // seed에서 직접 삭제
    node(selected_seed_node) {
      sh(script: "find '${sync_cfg.quarantine_root_path}' -type f -exec rm -f {} + 2>/dev/null; find '${sync_cfg.quarantine_root_path}' -type d -empty -delete 2>/dev/null || true", returnStatus: true)
      echo "[${location_code}] seed quarantine 최종 삭제 완료"

      // peer에도 quarantine 정리 전파
      selected_peer_nodes.each { peer ->
        def pip = ip_map[peer] ?: peer
        sh(returnStatus: true, script: """
          ssh -i ${jenkins_key_del} -o StrictHostKeyChecking=no -o ConnectTimeout=10 \
            ${ssh_user}@${pip} \
            "find '${sync_cfg.quarantine_root_path}' -type f -exec rm -f {} + 2>/dev/null; \
             find '${sync_cfg.quarantine_root_path}' -type d -empty -delete 2>/dev/null || true"
        """)
        echo "[${location_code}] peer(${pip}) quarantine 최종 삭제 완료"
      }
    }
  }

  return [success: ok]
}

def pickSeedForReconcile(List<String> online_nodes) {
  def nodes_with_state = []
  online_nodes.each { name ->
    try {
      node(name) {
        def exists = sh(returnStatus: true, script: "test -f /var/lib/oob-sync/last_sync_state.json")
        if (exists == 0) nodes_with_state << name
      }
    } catch (e) { /* skip */ }
  }
  if (nodes_with_state.size() > 0) return nodes_with_state.sort().first()
  return online_nodes.sort().first()
}
